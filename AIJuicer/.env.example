# Scheduler
AIJUICER_DATABASE_URL=postgresql+asyncpg://aijuicer:aijuicer@localhost:5432/ai_juicer
AIJUICER_REDIS_URL=redis://localhost:6379/0
AIJUICER_ARTIFACT_ROOT=/var/lib/aijuicer/artifacts

AIJUICER_HEARTBEAT_TIMEOUT_SEC=90
# Agent presence 心跳：SDK 每 5s 续一次 Redis TTL key
# 漏 1 次（>5s 没续上）→ 列表标记为离线但仍显示
# 漏 3 次（>15s 没续上）→ key 自动过期，列表消失
AIJUICER_HEARTBEAT_INTERVAL_SEC=5
AIJUICER_PRESENCE_TTL_SEC=15
AIJUICER_MAX_RETRIES=3

AIJUICER_LOG_LEVEL=INFO
# 日志格式：kv（半结构化，默认）/ json（给收集器）/ console（dev 友好）
AIJUICER_LOG_FORMAT=kv
# 同时落盘到该文件（10MB × 5 滚动）
AIJUICER_LOG_FILE=/Users/lapsdoor/phantom/logs/ai-juicer.log
